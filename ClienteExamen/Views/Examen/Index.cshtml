@model ExamenViewModel

<h2>Administración de Exámenes</h2>

<form method="post" class="mb-3">
<div class="mb-3">
       <label class="form-label">Modo de ejecución:</label><br />
        <div class="form-check form-check-inline">
            <input class="form-check-input" type="radio" name="UsarSPs" value="true"
               @(Model.UsarSPs ? "checked" : "") />
        <label class="form-check-label">Usar SPs</label>
        </div>
        <div class="form-check form-check-inline">
            <input class="form-check-input" type="radio" name="UsarSPs" value="false"
               @(!Model.UsarSPs ? "checked" : "") />
        <label class="form-check-label">Usar Web Service</label>
        </div>

    </div>
        <div class="mb-3">
        <label class="form-label">Id</label>
        <input asp-for="Id" class="form-control" />
    </div>
    <div class="mb-3">
        <label class="form-label">Nombre</label>
        <input asp-for="Nombre" class="form-control" />
    </div>
    <div class="mb-3">
        <label class="form-label">Descripción</label>
        <input asp-for="Descripcion" class="form-control" />
    </div>

    <div class="mb-3">
        <button formaction="/Examen/Agregar" type="submit" class="btn btn-success">Agregar</button>
        <button formaction="/Examen/Actualizar" type="submit" class="btn btn-primary">Actualizar</button>
        <button formaction="/Examen/Eliminar" type="submit" class="btn btn-danger">Eliminar</button>
        <button formaction="/Examen/Consultar" type="submit" class="btn btn-warning">Consultar</button>
    </div>
</form>

@if (!string.IsNullOrEmpty(Model.Mensaje))
{
    <div style="border:1px solid #ccc; padding:10px; background-color:#f9f9f9;">
        <h3>Mensaje de la respuesta</h3>
        <p>@Model.Mensaje</p>
    </div>
}

@if (Model.ListaExamenes?.Count > 0)
{
    <h3>Resultados de la consulta</h3>

    <table class="table table-striped table-hover">
    <thead class="table-success">
        <tr>
            <th>Id</th>
            <th>Nombre</th>
            <th>Descripción</th>
        </tr>
    </thead>
    <tbody>
       @foreach (var examen in Model.ListaExamenes)
        {
            <tr>
                <form method="post" asp-controller="Examen" asp-action="Actualizar">
                    <input type="hidden" name="UsarSPs" value="@Model.UsarSPs" />
                    <td>
                        <input type="text" name="IdExamen" value="@examen.IdExamen" 
                               class="form-control form-control-sm" readonly />
                        <input type="hidden" name="Id" value="@examen.IdExamen" />

                    </td>
                    <td>
                        <input type="text" name="Nombre" value="@examen.Nombre" 
                               class="form-control form-control-sm" />
                    </td>
                    <td>
                        <input type="text" name="Descripcion" value="@examen.Descripcion" 
                               class="form-control form-control-sm" />
                    </td>
                    <td>
                        <button type="submit" class="btn btn-primary btn-sm">
                            <i class="bi bi-pencil-square"></i> Guardar
                        </button>
                    </td>
                </form>
                <form method="post" asp-controller="Examen" asp-action="Eliminar">
                    <td colspan="4">
                        <input type="hidden" name="Id" value="@examen.IdExamen" />
                        <button type="submit" class="btn btn-danger btn-sm">
                            <i class="bi bi-trash"></i> Eliminar
                        </button>
                    </td>
                </form>
            </tr>
        }
    </tbody>
    </table>   
}

